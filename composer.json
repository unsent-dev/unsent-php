{
    "name": "unsent-dev/unsent",
    "version": "1.0.4",
    "description": "PHP SDK for the Unsent API - Send transactional emails with ease",
    "type": "library",
    "license": "MIT",
    "keywords": ["email", "api", "unsent", "transactional-email", "sdk"],
    "homepage": "https://unsent.dev",
    "repository": {
        "type": "git",
        "url": "https://github.com/unsent-dev/unsent-php.git"
    },
    "support": {
        "issues": "https://github.com/unsent-dev/unsent-php/issues",
        "source": "https://github.com/unsent-dev/unsent-php",
        "docs": "https://docs.unsent.dev"
    },
    "authors": [
        {
            "name": "Unsent"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "mockery/mockery": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "UnsentDev\\Unsent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UnsentDev\\Unsent\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
